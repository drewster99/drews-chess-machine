.claude/*
!.claude/skills/

# LLVM coverage raw counter files written when a binary built with
# -fprofile-instr-generate (Scheme > Test > Code Coverage enabled)
# exits. Normally lands under DerivedData, but appears at the repo
# root if the binary is launched directly from here.
*.profraw

# Python bytecode cache, auto-generated by CPython when the autotrain
# skill's helper modules get imported.
__pycache__/

# Swift Package Manager build directory. SPM dumps compiled modules,
# precompiled module caches (.pcm), and a build database here on every
# build — none of which should be checked in.
.build/

# macOS Finder metadata sidecar files.
.DS_Store

# Xcode per-user UI state. Window layouts, breakpoints set in this
# checkout, sidebar selection, etc. Strictly per-user; not part of the
# project.
*.xcuserstate
xcuserdata/
